<?xml version="1.0"?>
<!DOCTYPE module PUBLIC "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN" "https://checkstyle.org/dtds/configuration_1_3.dtd">

<module name="Checker">

  <property name="charset" value="UTF-8" />
  <property name="severity" value="warning" />

  <!-- Длина строки -->
  <module name="LineLength">
    <property name="fileExtensions" value="java" />
    <property name="max" value="120" />
    <property name="ignorePattern" value="^package.*|^import.*|a href|href|http://|https://|ftp://" />
  </module>

  <!-- Запрет табуляции -->
  <module name="FileTabCharacter">
    <property name="eachLine" value="true" />
  </module>

  <!-- Перевод строки в конце файла -->
  <module name="NewlineAtEndOfFile">
    <property name="lineSeparator" value="lf" />
  </module>

  <module name="TreeWalker">

    <property name="fileExtensions" value="java" />

    <!-- Имена классов -->
    <module name="TypeName">
      <property name="format" value="^[A-Z][a-zA-Z0-9]*$" />
    </module>

    <!-- Имена методов -->
    <module name="MethodName">
      <property name="format" value="^[a-z][a-zA-Z0-9]*$" />
    </module>

    <!-- Имена констант -->
    <module name="ConstantName">
      <property name="format" value="^[A-Z][A-Z0-9]*(_[A-Z0-9]+)*$" />
    </module>

    <!-- Запрет System.out.println -->
    <module name="RegexpSinglelineJava">
      <property name="format" value="System\.out\.println" />
      <property name="message" value="Используйте логгер вместо System.out.println" />
      <property name="ignoreComments" value="true" />
    </module>

    <!-- Обязательные фигурные скобки -->
    <module name="NeedBraces">
      <property name="tokens"
        value="LITERAL_DO, LITERAL_ELSE, LITERAL_FOR, LITERAL_IF, LITERAL_WHILE" />
    </module>

    <!-- Запрет неиспользуемых импортов -->
    <module name="UnusedImports" />

    <!-- Запрет wildcard импортов -->
    <module name="AvoidStarImport">
      <property name="excludes" value="java.lang,java.util" />
    </module>

    <!-- Порядок модификаторов -->
    <module name="ModifierOrder" />

    <!-- Максимальная сложность метода -->
    <module name="CyclomaticComplexity">
      <property name="max" value="15" />
    </module>

    <!-- Максимальная длина метода -->
    <module name="MethodLength">
      <property name="max" value="80" />
      <property name="countEmpty" value="false" />
    </module>

  </module>
</module>